{
  "name": "boatrent-mobile",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "npx cross-env EXPO_PUBLIC_APP_VARIANT=client expo start",
    "start:client": "npx cross-env EXPO_PUBLIC_APP_VARIANT=client expo start",
    "start:client:clear": "npx cross-env EXPO_PUBLIC_APP_VARIANT=client expo start --clear",
    "start:owner": "npx cross-env EXPO_PUBLIC_APP_VARIANT=owner expo start",
    "start:owner:clear": "npx cross-env EXPO_PUBLIC_APP_VARIANT=owner expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo-google-fonts/jost": "^0.4.2",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/datetimepicker": "8.2.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.10.1",
    "axios": "^1.5.1",
    "expo": "~51.0.28",
    "expo-build-properties": "^1.0.10",
    "expo-constants": "~16.0.2",
    "expo-font": "~12.0.10",
    "expo-image-picker": "~15.0.7",
    "expo-linear-gradient": "~14.0.1",
    "expo-splash-screen": "~0.27.7",
    "expo-status-bar": "~1.12.1",
    "lucide-react-native": "^0.441.0",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "~3.31.1",
    "react-native-webview": "13.8.6",
    "react-native-yamap": "^4.8.3",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "cross-env": "^7.0.3"
  },
  "private": true
}
