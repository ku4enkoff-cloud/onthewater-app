PORT=3000
JWT_SECRET=your_jwt_secret_key

# PostgreSQL (используйте DATABASE_URL или PGHOST/PGPORT/PGDATABASE/PGUSER/PGPASSWORD)
DATABASE_URL=postgresql://user:password@localhost:5432/boatrent
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=boatrent
# PGUSER=postgres
# PGPASSWORD=your_password

# Redis (опционально, для Socket.IO в нескольких экземплярах)
REDIS_URL=redis://localhost:6379

# Yandex S3 Object Storage
YANDEX_S3_ACCESS_KEY=your_s3_access_key
YANDEX_S3_SECRET_KEY=your_s3_secret_key
YANDEX_S3_ENDPOINT=https://storage.yandexcloud.net
YANDEX_S3_BUCKET=boatrent-media
YANDEX_S3_REGION=ru-central1

# Yandex Kassa (Yookassa)
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_yookassa_secret_key
