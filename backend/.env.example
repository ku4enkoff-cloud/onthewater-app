PORT=3000
JWT_SECRET=your_jwt_secret_key

# Подтверждение email: базовый URL API (для ссылки в письме)
APP_URL=https://api.onthewater.ru
# SMTP для отправки писем (без настроек письма не отправляются, аккаунт всё равно создаётся)
# SMTP_HOST=smtp.timeweb.ru
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@gmail.com
# SMTP_PASS=app_password
# MAIL_FROM=noreply@onthewater.ru

# Защита API: разрешённые источники для CORS (через запятую). Пусто = разрешены все.
# ALLOWED_ORIGINS=https://onthewater.ru,https://admin.onthewater.ru,capacitor://localhost
# Лимит запросов с одного IP за 15 минут (по умолчанию 300).
# RATE_LIMIT_MAX_PER_15MIN=300

# PostgreSQL (используйте DATABASE_URL или PGHOST/PGPORT/PGDATABASE/PGUSER/PGPASSWORD)
DATABASE_URL=postgresql://user:password@localhost:5432/boatrent
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=boatrent
# PGUSER=postgres
# PGPASSWORD=your_password

# Redis (опционально, для Socket.IO в нескольких экземплярах)
# Без пароля: redis://localhost:6379
# С паролем:   redis://:ваш_пароль@localhost:6379  (двоеточие перед паролем обязательно)
REDIS_URL=redis://localhost:6379

# Yandex S3 Object Storage
YANDEX_S3_ACCESS_KEY=your_s3_access_key
YANDEX_S3_SECRET_KEY=your_s3_secret_key
YANDEX_S3_ENDPOINT=https://storage.yandexcloud.net
YANDEX_S3_BUCKET=boatrent-media
YANDEX_S3_REGION=ru-central1

# Yandex Kassa (Yookassa)
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_yookassa_secret_key
